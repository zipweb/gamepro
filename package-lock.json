{
  "name": "lms-platform-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "lms-platform-monorepo",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "database"
      ],
      "engines": {
        "node": ">=20.0.0"
      }
    },
    "apps/backend": {
      "name": "@lms/backend",
      "version": "0.1.0",
      "dependencies": {
        "@lms/config": "0.1.0",
        "@lms/shared": "0.1.0"
      }
    },
    "apps/frontend": {
      "name": "@lms/frontend",
      "version": "0.1.0",
      "dependencies": {
        "@lms/config": "0.1.0",
        "@lms/shared": "0.1.0"
      }
    },
    "database": {
      "name": "@lms/database",
      "version": "0.1.0"
    },
    "node_modules/@lms/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@lms/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@lms/database": {
      "resolved": "database",
      "link": true
    },
    "node_modules/@lms/eslint-config": {
      "resolved": "packages/eslint-config",
      "link": true
    },
    "node_modules/@lms/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@lms/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@lms/tsconfig": {
      "resolved": "packages/tsconfig",
      "link": true
    },
    "packages/config": {
      "name": "@lms/config",
      "version": "0.1.0"
    },
    "packages/eslint-config": {
      "name": "@lms/eslint-config",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@lms/shared",
      "version": "0.1.0"
    },
    "packages/tsconfig": {
      "name": "@lms/tsconfig",
      "version": "0.1.0"
    }
  }
}
