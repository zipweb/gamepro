{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "backend",
      "source": {
        "repo": "https://github.com/zipweb/gamepro",
        "rootDirectory": "."
      },
      "variables": {
        "PORT": "3000",
        "JWT_SECRET": "supersecret",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}"
      },
      "startCommand": "npm install --legacy-peer-deps && node apps/backend/src/main.js"
    },
    {
      "name": "frontend",
      "source": {
        "repo": "https://github.com/zipweb/gamepro",
        "rootDirectory": "."
      },
      "variables": {
        "NEXT_PUBLIC_API_URL": "${{backend.RAILWAY_PUBLIC_DOMAIN}}"
      },
      "startCommand": "npm install --legacy-peer-deps && cd apps/frontend && npm run build && npm start"
    },
    {
      "name": "Postgres",
      "plugin": "postgres"
    }
  ]
}
